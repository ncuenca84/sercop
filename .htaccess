Options -Indexes
Options +FollowSymLinks

# Límites de tamaño de solicitud (evita error 413 en formularios grandes)
LimitRequestBody 20971520
<IfModule mod_php.c>
    php_value post_max_size 20M
    php_value upload_max_filesize 10M
</IfModule>
<IfModule lsapi_module>
    php_value post_max_size 20M
    php_value upload_max_filesize 10M
</IfModule>

RewriteEngine On

# Forzar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Saltar archivos y directorios que existen físicamente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás → index.php
RewriteRule ^ index.php [L]

# Proteger archivos sensibles
<FilesMatch "^\.env|\.env\..*|composer\.(json|lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Deshabilitar ejecución de PHP en uploads
<IfModule mod_php.c>
    <Directory "storage/uploads">
        php_flag engine off
    </Directory>
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php83" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
